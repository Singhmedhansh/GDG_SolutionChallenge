# Gemini API key (required for natural-language summaries)
GEMINI_API_KEY=

# Comma-separated list of allowed CORS origins for the frontend.
# Local dev default: http://localhost:5173,http://localhost:5174
# Production example: https://fairscan.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Port for uvicorn to bind on. Cloud Run injects this automatically;
# do NOT hardcode it there.
PORT=8000
